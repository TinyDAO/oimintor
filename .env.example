# —— AI 交易分析（OpenAI 兼容 Chat Completions）——
#
# 本地：Vite 开发/预览的 /api/ai/chat 中间件会读取这些变量（不进前端 bundle）。
# Vercel：在 Project → Environment Variables 配置同名变量；
#         生产请求由 api/ai/chat.ts Serverless 函数处理（路径仍为 /api/ai/chat）。
# 系统提示词在服务端 api/ai/traderAiMessages.ts；前端只 POST marketPayload。

AI_API_KEY=
# 可选，默认 https://api.openai.com/v1（可改为其他兼容网关根路径，勿带尾斜杠后的路径）
AI_API_BASE_URL=
# 可选，默认 gpt-4o-mini
AI_MODEL=

# 可选：前端请求路径（默认 /api/ai/chat）
# VITE_AI_CHAT_PATH=/api/ai/chat

# 可选：AI 分析入口开关（默认开启，可不写）
# 需要关闭时取消下行注释或设为 false / 0 / off / no
# VITE_ENABLE_AI_ANALYSIS=false

# —— 聚合 API（/api/market-insights、/api/variant-scan）——
# 由 Vercel Serverless 提供，无需在 .env 里配密钥；若线上访问 404：
# 1) 仓库是 monorepo 时，Vercel 项目 Settings → General → Root Directory 设为 oi-monitor
# 2) 确认部署日志里生成了 Serverless Functions，且已包含 api/market-insights.ts 与 api/variant-scan.ts
# 3) 纯静态托管（如仅上传 dist）不会包含 /api，需用 Vercel/Node 或自建反代
# 注：全量 insights JSON 会超过 Vercel 4.5MB 限制；/api/market-insights 已做列表瘦身，详情在抽屉内再拉全量。
# 日志里 url.parse() 弃用提示来自 Node/依赖，与 502 无直接因果关系。
