# —— AI 交易分析（OpenAI 兼容 Chat Completions）——
#
# 本地：Vite 开发/预览的 /api/ai/chat 中间件会读取这些变量（不进前端 bundle）。
# Vercel：在 Project → Environment Variables 配置同名变量；
#         生产请求由 api/ai/chat.ts Serverless 函数处理（路径仍为 /api/ai/chat）。
# 系统提示词在服务端 api/ai/traderAiMessages.ts；前端只 POST marketPayload。

AI_API_KEY=
# 可选，默认 https://api.openai.com/v1（可改为其他兼容网关根路径，勿带尾斜杠后的路径）
AI_API_BASE_URL=
# 可选，默认 gpt-4o-mini
AI_MODEL=

# 可选：前端请求路径（默认 /api/ai/chat）
# VITE_AI_CHAT_PATH=/api/ai/chat

# 可选：AI 分析入口开关（默认开启，可不写）
# 需要关闭时取消下行注释或设为 false / 0 / off / no
# VITE_ENABLE_AI_ANALYSIS=false
